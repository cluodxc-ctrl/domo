<style>
  body {
    background-color: #ffe4e1; 
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
  }

  .container {
    background-color: lightblue;
    padding: 20px;
    border-radius: 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    display: flex;
    gap: 10px; 
    direction: rtl;
  }

  input {
    border-radius: 50px;
    padding: 10px 15px;
    border: none;
    outline: none; 
    font-size: 16px;
  }

  button {
    border-radius: 50px; 
    border: none;
    padding: 10px 20px;
    background-color: #4CAF50; 
    color: white;
    cursor: pointer;
    font-weight: bold;
    transition: 0.2s;
  }

  button:hover {
    background-color: #45a049; }

  #list {
    list-style-type: none;للقائ
    padding: 0;
    margin-top: 20px;
    text-align: right;
  }
</style>

<div>
  <div class="container">
    <input id="myInput" placeholder="اكتب مهمة...">
    <button id="addBtn">إضافة</button>
  </div>
  
  
  <ul id="list"></ul>
 

</div>




<script>

const taskInput =    document.getElementById ("myInput")

const addBtn = document.getElementById ("addBtn")

const todoList = document.getElementById("list");


addBtn.addEventListener ("click",function () {
 
 
 let taskText = taskInput.value;
 let newTodo = document.createElement("li")
 newTodo.textContent = taskText;
 todoList.appendChild(newTodo);

 
});







</script>